{
  "expo": {
    "scheme": "flota",
    "web": {
      "bundler": "metro",
      "favicon": "./src/shared/assets/favicon.png"
    },
    "owner": "ontologyio",
    "extra": {
      "storybookEnabled": true,
      "enablePlayground": true,
      "eas": {
        "projectId": "ef8549d0-0b3d-456b-955a-4f17e2e241f3",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "NotificationService",
                  "bundleIdentifier": "com.flota.app.richpush"
                },
                {
                  "targetName": "NotificationService",
                  "bundleIdentifier": "com.flota.app.richpush"
                }
              ]
            }
          }
        }
      },
      "router": {}
    },
    "name": "Flota",
    "slug": "hello-word",
    "version": "1.0.0",
    "runtimeVersion": "1.0",
    "orientation": "portrait",
    "icon": "./src/shared/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/shared/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#141414"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": false,
      "bundleIdentifier": "com.flota.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSCameraUsageDescription": "Flota needs camera access to capture images within the demo features.",
        "NSPhotoLibraryUsageDescription": "Flota needs photo library access to upload images within the demo features.",
        "NSUserTrackingUsageDescription": "This identifier is used for analytics in production builds."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "icon": "./src/shared/assets/icon.png",
      "package": "com.flota.app",
      "permissions": ["com.google.android.gms.permission.AD_ID"]
    },
    "updates": {
      "enabled": false,
      "url": "https://u.expo.dev/ef8549d0-0b3d-456b-955a-4f17e2e241f3"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-router",
      "expo-asset",
      [
        "expo-updates",
        {
          "username": "TODO-your-expo-account"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-tracking-transparency",
      "expo-image",
      "expo-sharing",
      "expo-web-browser"
    ]
  }
}
